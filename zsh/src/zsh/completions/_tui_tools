#compdef y lzd rss lpa lpas gogh ogogh

# Completion for TUI application shortcuts

_tui_tools_completion() {
  local context state state_descr line
  typeset -A opt_args

  case "$service" in
    y)
      _alternative \
        'files:files:_comp_files_no_dirs' \
        'directories:directories:_directories'
      ;;
    lzd)
      _message 'LazyDocker TUI'
      ;;
    rss)
      _message 'Newsboat RSS reader'
      ;;
    lpa)
      _message 'LastPass CLI'
      ;;
    lpas)
      _arguments \
        '1:entry name:' \
        && return 0
      ;;
    gogh)
      _message 'Install Gogh terminal color schemes'
      ;;
    ogogh)
      _message 'Open Gogh website in browser'
      ;;
  esac
}

_tui_tools_completion "$@"
