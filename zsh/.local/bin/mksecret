#!/usr/bin/env zsh
#
# mksecret - back up secret files to a private `secrets` repo (sibling of
#            dotfiles), and restore them on new machines.
#
# MENTAL MODEL
#   - `add <file>`   tracks that one file.
#   - `add <folder>` tracks everything under it, now and in the future
#                    (a "watched" folder - re-scanned on every sync).
#   - No wildcards. `add` takes concrete paths; a literal glob is refused with a
#     hint. New files inside a watched folder sync automatically; a brand-new
#     folder (e.g. a new project's memory dir) needs its own `add`.
#   - Excluding is just gitignore: add patterns to secrets/.gitignore and they
#     are never captured or committed (e.g. `*.jsonl` to skip transcripts).
#
# REGISTRY (the secrets repo tree IS the registry). Two namespaces:
#   secrets/<repo-relative>            <- $DOTFILES/<repo-relative>   (in-tree)
#   secrets/_external/<home-relative>  <- $HOME/<home-relative>       (out-of-tree)
#   secrets/.mksecret/watch            watched folders (committed, shared)

emulate -L zsh
setopt no_unset pipe_fail

CODE_HOME="${XDG_CODE_HOME:-$HOME/src}"
DOTFILES="$CODE_HOME/dotfiles"
SECRETS="$CODE_HOME/secrets"
EXTERNAL_PREFIX="_external"

log()  { print -r -- "mksecret: $*"; }
warn() { print -r -- "mksecret: warning: $*" >&2; }
die()  { print -r -- "mksecret: error: $*" >&2; exit 1; }

# --- path <-> registry mapping ----------------------------------------------

# registry-relative path -> real source path on this machine
_source_of() {
  local rel="$1"
  if [[ "$rel" == "$EXTERNAL_PREFIX/"* ]]; then
    print -r -- "$HOME/${rel#$EXTERNAL_PREFIX/}"
  else
    print -r -- "$DOTFILES/$rel"
  fi
}

# real path (arg to `add`) -> registry-relative destination.
# :A resolves symlinks (a deployed link into dotfiles maps to a tree secret);
# both sides normalized so a symlinked $HOME/$DOTFILES (macOS /var) still matches.
_registry_dest() {
  local abs="${1:A}"
  local df="${DOTFILES:A}" hm="${HOME:A}"
  if [[ "$abs" == "$df/"* ]]; then
    print -r -- "${abs#$df/}"
  elif [[ "$abs" == "$hm/"* ]]; then
    print -r -- "$EXTERNAL_PREFIX/${abs#$hm/}"
  else
    return 1
  fi
}

# True if a registry-relative path is NOT a real secret: meta files, or anything
# excluded by secrets/.gitignore (the single, familiar place to exclude things).
_excluded() {
  local rel="$1"
  [[ "$rel" == ".gitignore" ]] && return 0
  git -C "$SECRETS" check-ignore -q -- "$rel"
}

# List every tracked secret, one registry-relative path per line.
_registry_files() {
  [[ -d "$SECRETS" ]] || die "secrets repo not found at $SECRETS"
  local f rel
  find "$SECRETS" -type f -not -path '*/.git/*' -not -path '*/.mksecret/*' -print |
    while IFS= read -r f; do
      rel="${f#$SECRETS/}"
      _excluded "$rel" && continue
      print -r -- "$rel"
    done
}

# --- watched folders ---------------------------------------------------------

_watch_file() { print -r -- "$SECRETS/.mksecret/watch"; }

_watch_add() {
  local rel="$1" wf; wf="$(_watch_file)"
  mkdir -p "${wf:h}"
  grep -qxF -- "$rel" "$wf" 2>/dev/null || print -r -- "$rel" >> "$wf"
}

_watched_folders() {
  local wf; wf="$(_watch_file)"
  [[ -f "$wf" ]] && grep -vE '^[[:space:]]*(#|$)' "$wf"
}

# Copy every non-excluded file under a live directory into the registry.
_capture_under() {
  local root="$1" f frel d
  find "$root" -type f -not -path '*/.git/*' -not -path '*/.mksecret/*' -print |
    while IFS= read -r f; do
      frel="$(_registry_dest "$f")" || continue
      _excluded "$frel" && continue
      d="$SECRETS/$frel"
      if [[ ! -e "$d" ]] || ! cmp -s "$f" "$d"; then
        mkdir -p "${d:h}"
        cp "$f" "$d"
        log "captured $frel"
      fi
    done
}

# Ensure a tree-namespace secret is gitignored in dotfiles (no-op for _external).
_guardrail() {
  local rel="$1"
  [[ "$rel" == "$EXTERNAL_PREFIX/"* ]] && return 0
  git -C "$DOTFILES" check-ignore -q -- "$rel" && return 0
  print -r -- "/$rel" >> "$DOTFILES/.gitignore"
  log "added /$rel to dotfiles/.gitignore"
}

# --- commands ----------------------------------------------------------------

cmd_add() {
  (( $# )) || die "add: give one or more paths"

  local arg
  # Refuse literal glob patterns - mksecret tracks paths, not patterns.
  for arg in "$@"; do
    if [[ ( "$arg" == *"*"* || "$arg" == *"?"* || "$arg" == *"["* ) && ! -e "$arg" ]]; then
      warn "'$arg' looks like a pattern - mksecret tracks paths, not patterns."
      warn "to track everything under a directory, add the directory itself, e.g.:"
      warn "    mksecret add ~/.claude/projects/<project>/memory"
      return 1
    fi
  done

  # Sanity confirm when many items are added at once (e.g. a shell-expanded
  # wildcard) so an accidental match is visible before anything happens.
  if (( $# >= 3 )) && [[ -t 0 ]]; then
    print -r -- "mksecret: about to add these $# items:"
    for arg in "$@"; do print -r -- "    $arg"; done
    if ! read -q "?mksecret: proceed? [y/N] "; then
      print; warn "aborted, nothing added"; return 1
    fi
    print
  fi

  local abs rel dest
  for arg in "$@"; do
    abs="${arg:A}"
    [[ -e "$abs" ]] || { warn "add: $arg does not exist, skipping"; continue; }
    if ! rel="$(_registry_dest "$abs")"; then
      warn "add: $arg is outside \$HOME, skipping"
      continue
    fi
    if [[ -d "$abs" ]]; then
      _watch_add "$rel"
      log "watching folder $rel (everything under it, minus secrets/.gitignore excludes)"
      _capture_under "$abs"
    else
      dest="$SECRETS/$rel"
      mkdir -p "${dest:h}"
      cp "$abs" "$dest"
      log "registered $rel"
    fi
    _guardrail "$rel"
  done
  log "run 'mksecret sync' (or commit dotfiles) to push to the secrets repo"
}

cmd_sync() {
  # 1. re-scan each watched folder so new files in it are captured automatically
  local wf_rel live
  while IFS= read -r wf_rel; do
    if [[ "$wf_rel" == "$EXTERNAL_PREFIX/"* ]]; then
      live="$HOME/${wf_rel#$EXTERNAL_PREFIX/}"
    else
      live="$DOTFILES/$wf_rel"
    fi
    [[ -d "$live" ]] && _capture_under "$live"
  done < <(_watched_folders)

  # 2. refresh every tracked secret from its live source
  local rel src dest synced=0 skipped=0
  while IFS= read -r rel; do
    src="$(_source_of "$rel")"
    dest="$SECRETS/$rel"
    if [[ -e "$src" ]]; then
      mkdir -p "${dest:h}"
      cp "$src" "$dest"
      (( synced++ ))
    else
      warn "no source for $rel (expected $src) - leaving as-is"
      (( skipped++ ))
    fi
  done < <(_registry_files)
  log "synced $synced file(s), skipped $skipped"

  # 3. commit + push (fail loudly on conflict; never force)
  git -C "$SECRETS" add -A
  if git -C "$SECRETS" diff --cached --quiet; then
    log "secrets repo already up to date, nothing to commit"
    return 0
  fi
  git -C "$SECRETS" commit -q -m "sync: $(date -u +%Y-%m-%dT%H:%M:%SZ)" || die "commit failed"
  log "committed changes to secrets repo"
  if git -C "$SECRETS" push -q; then
    log "pushed to secrets remote"
  else
    print -r -- "" >&2
    warn "PUSH TO SECRETS FAILED (likely a conflict / non-fast-forward)."
    warn "Your commit is saved locally. Resolve it with normal git:"
    warn "    cd $SECRETS && git pull --rebase && git push"
    return 1
  fi
}

cmd_restore() {
  local force=0
  [[ "${1:-}" == "--force" || "${1:-}" == "-f" ]] && force=1
  local rel src restored=0 skipped=0
  while IFS= read -r rel; do
    src="$(_source_of "$rel")"
    # Leak guardrail: never write a tree secret into the dotfiles tree unless it
    # is gitignored there (else `git add` in dotfiles could publish it).
    if [[ "$rel" != "$EXTERNAL_PREFIX/"* ]] && ! git -C "$DOTFILES" check-ignore -q -- "$rel"; then
      warn "refusing to restore $rel (not gitignored in dotfiles - would risk a public leak)"
      (( skipped++ ))
      continue
    fi
    if [[ -e "$src" && $force -eq 0 ]]; then
      log "skipped $rel (source exists: $src)"
      (( skipped++ ))
      continue
    fi
    mkdir -p "${src:h}"
    cp "$SECRETS/$rel" "$src"
    log "restored $rel -> $src"
    (( restored++ ))
  done < <(_registry_files)
  log "restored $restored file(s), skipped $skipped"
}

cmd_diff() {
  if (( $# )); then
    local abs="${1:A}" rel src
    if ! rel="$(_registry_dest "$abs")"; then
      rel="$1"   # maybe a registry-relative path was given directly
    fi
    [[ -f "$SECRETS/$rel" ]] || die "diff: $rel is not tracked"
    src="$(_source_of "$rel")"
    [[ -e "$src" ]] || die "diff: no source for $rel (expected $src)"
    # --no-index routes through the configured pager (delta), like normal git.
    git -C "$DOTFILES" diff --no-index -- "$SECRETS/$rel" "$src" || true
    return 0
  fi

  local rel src differ=0
  while IFS= read -r rel; do
    src="$(_source_of "$rel")"
    if [[ ! -e "$src" ]]; then
      print -r -- "  ??  $rel  (no source: $src)"
      continue
    fi
    if ! cmp -s "$SECRETS/$rel" "$src"; then
      print -r -- "  M   $rel"
      (( differ++ ))
    fi
  done < <(_registry_files)
  if (( differ )); then
    log "$differ file(s) differ - 'mksecret diff <path>' to view, 'mksecret sync' to update"
  else
    log "all secrets match their sources"
  fi
}

cmd_check() {
  local rel src
  local -a tree_unguarded missing_src
  while IFS= read -r rel; do
    src="$(_source_of "$rel")"
    [[ -e "$src" ]] || missing_src+=("$rel")
    if [[ "$rel" != "$EXTERNAL_PREFIX/"* ]]; then
      git -C "$DOTFILES" check-ignore -q -- "$rel" || tree_unguarded+=("$rel")
    fi
  done < <(_registry_files)

  local rc=0 x
  if (( ${#tree_unguarded} )); then
    rc=1
    warn "tree secrets NOT gitignored in dotfiles (leak risk on restore):"
    for x in $tree_unguarded; do print -r -- "    $x"; done
    warn "fix each with a dotfiles .gitignore entry (e.g. /$tree_unguarded[1])"
  fi
  if (( ${#missing_src} )); then
    log "tracked entries whose source is gone (deletion candidates):"
    for x in $missing_src; do print -r -- "    $x    (git -C $SECRETS rm '$x')"; done
  fi
  (( rc == 0 && ${#missing_src} == 0 )) && log "all good: every secret is guarded and has a live source"
  return $rc
}

cmd_install_hook() {
  local hook="$DOTFILES/.git/hooks/post-commit"
  if [[ ! -f "$hook" ]]; then
    print -r -- "#!/bin/sh" > "$hook"
    chmod +x "$hook"
  fi
  if grep -q 'MKSECRET_HOOK_START' "$hook" 2>/dev/null; then
    log "post-commit hook already installed"
    return 0
  fi
  cat >> "$hook" <<'EOF'
# MKSECRET_HOOK_START
"$HOME/.local/bin/mksecret" sync
# MKSECRET_HOOK_END
EOF
  chmod +x "$hook"
  log "installed secrets-sync into $hook"
}

usage() {
  cat <<'EOF'
mksecret - back up secret files to a private `secrets` repo

USAGE
  mksecret add <path...>   Track a secret and copy it into the secrets repo.
                             a FILE   -> tracks that one file
                             a FOLDER -> tracks everything under it, now and
                                         later (a "watched" folder)
                           Relative paths are fine; dotfiles-vs-external is
                           detected automatically. Wildcards are NOT a feature:
                           an unquoted glob is expanded by the shell to what
                           matches right now; a literal glob is refused with a
                           hint to add the folder instead. Adding 3+ items at
                           once asks for confirmation.
  mksecret sync            Refresh every tracked secret + re-scan watched
                           folders (capturing new files), then commit & push.
  mksecret restore [-f]    Copy secrets back to their sources (skip existing
                           unless --force/-f). Refuses non-gitignored tree secrets.
  mksecret diff [<path>]   List secrets that differ from their source, or show a
                           delta diff of one file.
  mksecret check           Audit: tree secrets missing a gitignore guardrail,
                           and tracked entries whose source no longer exists.
  mksecret install-hook    Run 'mksecret sync' from the dotfiles post-commit hook.
  mksecret -h | help       Show this help.

EXCLUDING
  Add gitignore patterns to secrets/.gitignore - anything matched is never
  captured or committed. e.g. add '*.jsonl' to skip Claude session transcripts.

LAYOUT
  secrets/<path>            <- $DOTFILES/<path>     (dotfiles-tree secret)
  secrets/_external/<path>  <- $HOME/<path>         (out-of-tree secret)
  secrets/.mksecret/watch   watched folders (committed, shared across machines)
EOF
}

main() {
  local sub="${1:-}"
  (( $# )) && shift
  case "$sub" in
    add)                  cmd_add "$@" ;;
    sync)                 cmd_sync "$@" ;;
    restore)              cmd_restore "$@" ;;
    diff)                 cmd_diff "$@" ;;
    check)                cmd_check "$@" ;;
    install-hook)         cmd_install_hook "$@" ;;
    -h|--help|help|'')    usage ;;
    *)                    die "unknown command '$sub' (try: mksecret -h)" ;;
  esac
}

main "$@"
