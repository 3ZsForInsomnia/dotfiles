#!/usr/bin/env zsh
#
# mksecret - keep a private `secrets` repo in sync with secret files that live
#            in (or alongside) the public `dotfiles` repo.
#
# The registry of "what is a secret" IS the secrets repo tree. Two namespaces:
#
#   secrets/<repo-relative>            -> source: $DOTFILES/<repo-relative>
#                                         (a file inside the dotfiles tree,
#                                          gitignored there; restored into the
#                                          tree so `stow` deploys it)
#
#   secrets/_external/<home-relative>  -> source: $HOME/<home-relative>
#                                         (a file that does NOT live in dotfiles,
#                                          e.g. a work script or ~/.claude memory;
#                                          restored straight into $HOME)
#
# gitignore is NOT the registry - it is only a leak guardrail that `add`
# maintains for dotfiles-tree secrets.

emulate -L zsh
setopt no_unset pipe_fail

CODE_HOME="${XDG_CODE_HOME:-$HOME/src}"
DOTFILES="$CODE_HOME/dotfiles"
SECRETS="$CODE_HOME/secrets"
EXTERNAL_PREFIX="_external"

# Names/patterns that live in the secrets tree but are NOT synced secrets.
_skip_name() {
  case "$1" in
    *.zwc|tags|tags.*|.DS_Store|.gitignore) return 0 ;;
    *) return 1 ;;
  esac
}

log()  { print -r -- "mksecret: $*"; }
warn() { print -r -- "mksecret: warning: $*" >&2; }
die()  { print -r -- "mksecret: error: $*" >&2; exit 1; }

# List every secret in the registry, one repo-relative path per line.
_registry_files() {
  [[ -d "$SECRETS" ]] || die "secrets repo not found at $SECRETS"
  local f rel
  find "$SECRETS" -type f -not -path '*/.git/*' -print | while IFS= read -r f; do
    rel="${f#$SECRETS/}"
    _skip_name "${rel:t}" && continue
    print -r -- "$rel"
  done
}

# Given a registry-relative path, echo its real source path on this machine.
_source_of() {
  local rel="$1"
  if [[ "$rel" == "$EXTERNAL_PREFIX/"* ]]; then
    print -r -- "$HOME/${rel#$EXTERNAL_PREFIX/}"
  else
    print -r -- "$DOTFILES/$rel"
  fi
}

# Given a real path (arg to `add`), echo its registry-relative destination.
# Resolves symlinks so a deployed link into dotfiles maps to a tree secret.
# Both sides are normalized with :A so a symlinked $HOME/$DOTFILES (e.g. macOS
# /var -> /private/var) still matches.
_registry_dest() {
  local abs="${1:A}"
  local df="${DOTFILES:A}" hm="${HOME:A}"
  if [[ "$abs" == "$df/"* ]]; then
    print -r -- "${abs#$df/}"
  elif [[ "$abs" == "$hm/"* ]]; then
    print -r -- "$EXTERNAL_PREFIX/${abs#$hm/}"
  else
    return 1
  fi
}

cmd_add() {
  (( $# )) || die "add: give one or more paths"
  local arg abs rel dest
  for arg in "$@"; do
    abs="${arg:A}"
    [[ -e "$abs" ]] || { warn "add: $arg does not exist, skipping"; continue; }
    if ! rel="$(_registry_dest "$abs")"; then
      warn "add: $arg is outside \$HOME, skipping"
      continue
    fi
    dest="$SECRETS/$rel"
    mkdir -p "${dest:h}"
    cp -R "$abs" "$dest"
    log "registered $rel"

    # Leak guardrail: dotfiles-tree secrets must be gitignored in dotfiles.
    if [[ "$rel" != "$EXTERNAL_PREFIX/"* ]]; then
      if git -C "$DOTFILES" check-ignore -q -- "$rel"; then
        : # already ignored (explicit entry or a pattern like *work*)
      else
        print -r -- "/$rel" >> "$DOTFILES/.gitignore"
        log "added /$rel to dotfiles/.gitignore"
      fi
    fi
  done
  log "run 'mksecret sync' (or commit dotfiles) to push to the secrets repo"
}

cmd_sync() {
  local rel src dest synced=0 skipped=0
  while IFS= read -r rel; do
    src="$(_source_of "$rel")"
    dest="$SECRETS/$rel"
    if [[ -e "$src" ]]; then
      mkdir -p "${dest:h}"
      cp -R "$src" "$dest"
      log "synced $rel"
      (( synced++ ))
    else
      warn "no source for $rel (expected $src) - leaving as-is"
      (( skipped++ ))
    fi
  done < <(_registry_files)

  log "synced $synced file(s), skipped $skipped"

  git -C "$SECRETS" add -A
  if git -C "$SECRETS" diff --cached --quiet; then
    log "secrets repo already up to date, nothing to commit"
    return 0
  fi

  git -C "$SECRETS" commit -q -m "sync: $(date -u +%Y-%m-%dT%H:%M:%SZ)" || die "commit failed"
  log "committed changes to secrets repo"

  if git -C "$SECRETS" push -q; then
    log "pushed to secrets remote"
  else
    print -r -- "" >&2
    warn "PUSH TO SECRETS FAILED (likely a conflict / non-fast-forward)."
    warn "Your commit is saved locally. Resolve it with normal git:"
    warn "    cd $SECRETS && git pull --rebase && git push"
    return 1
  fi
}

cmd_restore() {
  local force=0
  [[ "${1:-}" == "--force" || "${1:-}" == "-f" ]] && force=1
  local rel src restored=0 skipped=0
  while IFS= read -r rel; do
    src="$(_source_of "$rel")"
    # Leak guardrail: never write a tree secret into the dotfiles tree unless it
    # is gitignored there (else `git add` in dotfiles could publish it).
    if [[ "$rel" != "$EXTERNAL_PREFIX/"* ]] && ! git -C "$DOTFILES" check-ignore -q -- "$rel"; then
      warn "refusing to restore $rel (not gitignored in dotfiles - would risk a public leak)"
      (( skipped++ ))
      continue
    fi
    if [[ -e "$src" && $force -eq 0 ]]; then
      log "skipped $rel (source exists: $src)"
      (( skipped++ ))
      continue
    fi
    mkdir -p "${src:h}"
    cp -R "$SECRETS/$rel" "$src"
    log "restored $rel -> $src"
    (( restored++ ))
  done < <(_registry_files)
  log "restored $restored file(s), skipped $skipped"
}

cmd_diff() {
  if (( $# )); then
    local abs="${1:A}" rel src
    if ! rel="$(_registry_dest "$abs")"; then
      # maybe they passed a registry-relative path directly
      rel="$1"
    fi
    [[ -f "$SECRETS/$rel" ]] || die "diff: $rel is not in the secrets registry"
    src="$(_source_of "$rel")"
    [[ -e "$src" ]] || die "diff: no source for $rel (expected $src)"
    # --no-index routes through the configured pager (delta), like normal git.
    git -C "$DOTFILES" diff --no-index -- "$SECRETS/$rel" "$src" || true
    return 0
  fi

  local rel src differ=0
  while IFS= read -r rel; do
    src="$(_source_of "$rel")"
    if [[ ! -e "$src" ]]; then
      print -r -- "  ??  $rel  (no source: $src)"
      continue
    fi
    if ! cmp -s "$SECRETS/$rel" "$src"; then
      print -r -- "  M   $rel"
      (( differ++ ))
    fi
  done < <(_registry_files)
  if (( differ )); then
    log "$differ file(s) differ - 'mksecret diff <path>' to view, 'mksecret sync' to update"
  else
    log "all secrets match their sources"
  fi
}

cmd_check() {
  local rel src
  local -a tree_unguarded missing_src
  while IFS= read -r rel; do
    src="$(_source_of "$rel")"
    [[ -e "$src" ]] || missing_src+=("$rel")
    if [[ "$rel" != "$EXTERNAL_PREFIX/"* ]]; then
      git -C "$DOTFILES" check-ignore -q -- "$rel" || tree_unguarded+=("$rel")
    fi
  done < <(_registry_files)

  local rc=0 x
  if (( ${#tree_unguarded} )); then
    rc=1
    warn "tree secrets NOT gitignored in dotfiles (leak risk on restore):"
    for x in $tree_unguarded; do print -r -- "    $x"; done
    warn "fix each with a dotfiles .gitignore entry (e.g. /$tree_unguarded[1])"
  fi
  if (( ${#missing_src} )); then
    log "registry entries whose source is gone (deletion candidates):"
    for x in $missing_src; do print -r -- "    $x    (git -C $SECRETS rm '$x')"; done
  fi
  (( rc == 0 && ${#missing_src} == 0 )) && log "all good: every secret is guarded and has a live source"
  return $rc
}

cmd_install_hook() {
  local hook="$DOTFILES/.git/hooks/post-commit"
  if [[ ! -f "$hook" ]]; then
    print -r -- "#!/bin/sh" > "$hook"
    chmod +x "$hook"
  fi
  if grep -q 'MKSECRET_HOOK_START' "$hook" 2>/dev/null; then
    log "post-commit hook already installed"
    return 0
  fi
  cat >> "$hook" <<'EOF'
# MKSECRET_HOOK_START
"$HOME/.local/bin/mksecret" sync
# MKSECRET_HOOK_END
EOF
  chmod +x "$hook"
  log "installed secrets-sync into $hook"
}

usage() {
  cat <<'EOF'
mksecret - sync secret files with the private `secrets` repo

USAGE
  mksecret add <path...>     Register file(s)/folder as a secret (copy into
                             secrets repo; add dotfiles gitignore guardrail).
  mksecret sync              Copy every registered secret from its source into
                             the secrets repo, then commit & push.
  mksecret restore [-f]      Copy secrets back to their sources. Skips existing
                             files unless --force/-f is given.
  mksecret diff [<path>]     No arg: list secrets that differ from their source.
                             With a path: show a delta diff of that file.
  mksecret check             Audit: tree secrets missing a gitignore guardrail,
                             and registry entries whose source no longer exists.
  mksecret install-hook      Add secrets-sync to the dotfiles post-commit hook.
  mksecret -h | help         Show this help.

REGISTRY
  secrets/<path>             <- $DOTFILES/<path>        (dotfiles-tree secret)
  secrets/_external/<path>   <- $HOME/<path>            (out-of-tree secret)
EOF
}

main() {
  local sub="${1:-}"
  (( $# )) && shift
  case "$sub" in
    add)                  cmd_add "$@" ;;
    sync)                 cmd_sync "$@" ;;
    restore)              cmd_restore "$@" ;;
    diff)                 cmd_diff "$@" ;;
    check)                cmd_check "$@" ;;
    install-hook)         cmd_install_hook "$@" ;;
    -h|--help|help|'')    usage ;;
    *)                    die "unknown command '$sub' (try: mksecret -h)" ;;
  esac
}

main "$@"
