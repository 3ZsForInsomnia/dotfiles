# Basic files/directories
.DS_Store
.git/
node_modules
tags
tags.*

# Work stuff - automatically exclude files (with certain exceptions) that contain `work` in their filename
# THIS IS IMPORTANT, DO NOT TOUCH
*work*
!ai/.agent/skills/*work*

# Miscellaneous stuff that shouldn't be committed
resurrect
rss/.newsboat/cache.db
i3wm/.local/share/nvim
linear-client/config
*.zwc
.env*
base.yml

# Claude runtime data must never enter this PUBLIC repo. Config (settings.json,
# rules/) is tracked; projects/ (transcripts + memory) is not. Memory is backed
# up separately to the private secrets repo via mksecret.
claude/.claude/projects/
