# Main theming
theme = Catppuccin Mocha
background = #000000
font-family = FiraCode Nerd Font Mono
font-size = 16
font-thicken = true
font-thicken-strength = 255
bold-is-bright = true
adjust-underline-position = 0
adjust-underline-thickness = 2
adjust-cell-height = 5%

# Window
window-padding-x = 0
window-padding-y = 0
window-colorspace = display-p3
window-padding-balance = true

unfocused-split-opacity = 0.7
unfocused-split-fill = "#000000"

# Misc fun stuff
link-url = true
mouse-hide-while-typing = true
window-save-state = always
copy-on-select = clipboard
shell-integration-features = no-cursor,no-title,ssh-terminfo,ssh-env

# Tabs
keybind = alt+1=goto_tab:1
keybind = alt+2=goto_tab:2
keybind = alt+3=goto_tab:3
keybind = alt+4=goto_tab:4
keybind = alt+5=goto_tab:5
keybind = alt+6=goto_tab:6
keybind = alt+7=goto_tab:7
keybind = alt+8=goto_tab:8
keybind = alt+9=toggle_command_palette

# Opens new tab, or new window, depending
keybind = ctrl+shift+n=new_tab

# Splits
keybind = alt+h=goto_split:left
keybind = alt+l=goto_split:right
keybind = alt+k=goto_split:up
keybind = alt+j=goto_split:down
keybind = alt+z=toggle_split_zoom

## New Splits
keybind = alt+shift+h=new_split:left
keybind = alt+shift+j=new_split:down
keybind = alt+shift+k=new_split:up
keybind = alt+shift+l=new_split:right

# Instant resize (no mode). cmd chords never reach terminal apps like nvim,
# so these can't collide with any nvim keybind. Hold to repeat via key-repeat.
keybind = cmd+ctrl+h=resize_split:left,20
keybind = cmd+ctrl+l=resize_split:right,20
keybind = cmd+ctrl+k=resize_split:up,20
keybind = cmd+ctrl+j=resize_split:down,20

# Resize mode
keybind = alt+r=activate_key_table:resize
keybind = resize/left=resize_split:left,1
keybind = resize/right=resize_split:right,1
keybind = resize/up=resize_split:up,1
keybind = resize/down=resize_split:down,1
keybind = resize/h=resize_split:left,1
keybind = resize/l=resize_split:right,1
keybind = resize/k=resize_split:up,1
keybind = resize/j=resize_split:down,1
keybind = resize/shift+h=resize_split:left,10
keybind = resize/shift+l=resize_split:right,10
keybind = resize/shift+k=resize_split:up,10
keybind = resize/shift+j=resize_split:down,10
keybind = resize/escape=deactivate_key_table

# Scrollback into $EDITOR
keybind = alt+shift+f=write_scrollback_file:open

# Command palette items
keybind = cmd+shift+t=prompt_tab_title

# MacOS specific items
macos-titlebar-style = hidden
macos-non-native-fullscreen = true
keybind = ctrl+opt+enter=toggle_fullscreen
